PORT=3001
NODE_ENV=development

# Strava OAuth — get from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
STRAVA_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Session encryption
SESSION_SECRET=change_this_to_a_long_random_string

# Optional: PostgreSQL (leave blank to use in-memory store)
DATABASE_URL=postgresql://user:password@localhost:5432/fittrack

# Optional: Redis for session store
REDIS_URL=redis://localhost:6379

# Frontend origin (for CORS)
FRONTEND_URL=http://localhost:5173
