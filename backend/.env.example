PORT=3001
NODE_ENV=development

# Strava OAuth — get from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_strava_client_id
STRAVA_CLIENT_SECRET=your_strava_client_secret
# Local dev:
STRAVA_REDIRECT_URI=http://localhost:3001/api/auth/callback
# Production (Render):
# STRAVA_REDIRECT_URI=https://fittrack-v0fi.onrender.com/api/auth/callback

# Session encryption — use a long random string in production
SESSION_SECRET=change_this_to_a_long_random_string

# PostgreSQL — required (local or cloud)
# Local:   postgresql://postgres:password@localhost:5432/fittrack
# Neon:    postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/fittrack?sslmode=require
# Render:  provided automatically if you add a Render PostgreSQL instance
DATABASE_URL=postgresql://postgres:password@localhost:5432/fittrack

# Frontend origin (for CORS)
# Local dev:
FRONTEND_URL=http://localhost:5173
# Production (Netlify):
# FRONTEND_URL=https://runlytics.netlify.app

# Anthropic — required for AI Fitness Coach
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Strava Webhooks
# 1. Set a secret verify token (any random string you choose)
STRAVA_WEBHOOK_VERIFY_TOKEN=runlytics_webhook_secret_2026
# 2. Your public HTTPS callback URL
# Local dev (use ngrok):  https://<your-ngrok-id>.ngrok-free.app/api/webhooks/strava
# Production:             https://fittrack-v0fi.onrender.com/api/webhooks/strava
STRAVA_WEBHOOK_CALLBACK_URL=
